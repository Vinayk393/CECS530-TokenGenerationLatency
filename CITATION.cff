cff-version: 1.2.0
title: "Token-Generation Latency Benchmarking in LLaMA on Apple Silicon"
message: "If you use this benchmark suite, please cite it as below."
type: software
authors:
  - family-names: Krishna
    given-names: Vinay
    email: Vinay.Krishna01@student.csulb.edu
    affiliation: California State University, Long Beach
  - family-names: Maddineni
